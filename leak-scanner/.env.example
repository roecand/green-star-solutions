# --- Core (all optional for local dev; the app runs with zero keys) ---

# Database. Two modes:
#  - Local/dev: a plain SQLite file (default ./data/greenstar.db). Nothing to set.
#  - Production (Render/Vercel/any host without a persistent disk): use Turso,
#    a free hosted SQLite. Set both vars below and the file path is ignored.
# DATABASE_PATH=./data/greenstar.db
# TURSO_DATABASE_URL=libsql://your-db.turso.io
# TURSO_AUTH_TOKEN=your-turso-token

# Public URL of the app (used in emails and share links)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Signups with this email get the admin role (Greenstar admin bootstrap)
ADMIN_EMAIL=robert@greenstarsolutions.com

# Where "book a strategy call" CTAs point (Calendly etc.). Falls back to /contact.
NEXT_PUBLIC_BOOKING_URL=

# --- AI report generation (optional; deterministic fallback copy without it) ---
# ANTHROPIC_API_KEY=sk-ant-...
# AI_MODEL=claude-sonnet-5

# --- Stripe (optional; mock billing mode without it) ---
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRICE_STARTER=price_...
# STRIPE_PRICE_GROWTH=price_...
# STRIPE_PRICE_PRO=price_...

# --- Email via Resend (optional; emails are logged + recorded without it) ---
# RESEND_API_KEY=re_...
# EMAIL_FROM="Greenstar Scanner <scanner@greenstarsolutions.com>"
# ADMIN_NOTIFICATION_EMAIL=robert@greenstarsolutions.com
