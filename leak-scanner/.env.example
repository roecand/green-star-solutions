# --- Core (all optional for local dev; the app runs with zero keys) ---

# Database. Local SQLite file (default ./data/greenstar.db).
# On Railway, point this at the mounted persistent volume, e.g.
#   DATABASE_PATH=/data/greenstar.db
# DATABASE_PATH=./data/greenstar.db
#
# Optional hosted-SQLite (Turso) for disk-less hosts. Leave BOTH unset to use
# the local file above (the Railway deployment uses the file + a volume).
# TURSO_DATABASE_URL=libsql://your-db.turso.io
# TURSO_AUTH_TOKEN=your-turso-token

# Public URL of the app (used in emails and share links)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Funnel (lead-gen mode) ---

# Paid SaaS surface (pricing, upgrades, report gating) stays hidden while this
# is unset/false. Set to "true" only if you later want to sell subscriptions.
# NEXT_PUBLIC_BILLING_ENABLED=false

# The report's primary CTA ("Get My Personalized Fix Plan") opens this link
# (your scheduler — Calendly, GHL, etc.). If unset, the CTA still captures the
# lead and shows a "we'll reach out" confirmation instead of opening a link.
NEXT_PUBLIC_BOOKING_URL=

# Optional outbound webhook fired when a scan completes (e.g. GoHighLevel).
# Absent = no-op; never blocks a scan.
# LEAD_WEBHOOK_URL=

# Signups with this email get the admin role (Green Star admin bootstrap).
ADMIN_EMAIL=robert@greenstarsolutions.com

# Only needed if you seed an admin in production instead of signing up with
# ADMIN_EMAIL. Never ship the default password to production.
# SEED_ADMIN_PASSWORD=

# --- AI report generation (optional; deterministic fallback copy without it) ---
# ANTHROPIC_API_KEY=sk-ant-...
# AI_MODEL=claude-sonnet-5

# --- Email via Resend (optional; emails are logged + recorded without it) ---
# RESEND_API_KEY=re_...
# EMAIL_FROM="Green Star Scanner <scanner@green-starsolutions.com>"
# ADMIN_NOTIFICATION_EMAIL=robert@greenstarsolutions.com

# --- Stripe (billing is OFF by default; only used if NEXT_PUBLIC_BILLING_ENABLED=true) ---
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRICE_STARTER=price_...
# STRIPE_PRICE_GROWTH=price_...
# STRIPE_PRICE_PRO=price_...
